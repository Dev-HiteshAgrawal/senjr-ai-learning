# Firebase Auth (required — get from Firebase Console > Project Settings > Web App)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AI Tutor — set at least one (both are free-tier available)
# Groq: sign up at https://console.groq.com (free, no credit card)
GROQ_API_KEY=gsk_your_groq_api_key_here
# OpenAI: sign up at https://platform.openai.com (free credits included)
OPENAI_API_KEY=sk-your_openai_api_key_here